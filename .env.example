# Copy to .env and adjust. docker compose reads .env automatically.
#   cp .env.example .env

# Port for the web/API. Stay within your allocated range 7700-7799.
# 7700 was taken on the shared host — pick a free one (check: ss -ltn | grep ':77').
APP_PORT=7710

# Optional: run marker in-process via subprocess (shares GPU VRAM with Unlimited-OCR).
# MARKER_CMD=marker_single {input} --output_dir {output}
